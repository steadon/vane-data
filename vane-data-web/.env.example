# vane-data-web environment variables
# Copy to .env.local and adjust as needed

# Server-side: backend API URL used by Next.js rewrites (runtime-configurable)
# Change this to your deployed vane-data-api address
VANE_API_URL=http://localhost:8000

# Client-side: WebSocket service URL for real-time quote streaming
# Must be set at build time (Next.js NEXT_PUBLIC_* are inlined at build)
NEXT_PUBLIC_WS_URL=http://localhost:3003
